<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="300dp"
    android:height="200dp"
    android:viewportWidth="360"
    android:viewportHeight="240">

    <path
        android:pathData="M0,0 L360,0 L360,160 C270,200 90,120 0,160 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="360"
                android:endY="240"
                android:angle="100"
                android:startColor="#EAD6C4"
                android:centerColor="#D2B89B"
                android:endColor="#A67C52"
            android:tileMode="clamp" />
        </aapt:attr>
    </path>

</vector>
