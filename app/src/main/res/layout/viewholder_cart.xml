<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_margin="@dimen/dp_10">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/picCart"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/CornerImageView10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/quantityLayout"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:background="@drawable/grey_bg_full_corner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/plusCartBtn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/brown_bg"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/white"
            android:layout_margin="2dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/numberItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textStyle="bold"
            android:textColor="@color/brown"
            android:textSize="18sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/minusCartBtn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="-"
            android:textColor="@color/brown"
            android:background="@drawable/white_bg_circle"
            android:gravity="center"
            android:layout_margin="2dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Title"
        android:textColor="@color/brown"
        android:textStyle="bold"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/picCart"
        app:layout_constraintEnd_toStartOf="@id/quantityLayout"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp" />

    <TextView
        android:id="@+id/feeEachItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹0"
        android:textColor="@color/brown"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"
        app:layout_constraintStart_toStartOf="@id/txtTitle" />

    <TextView
        android:id="@+id/itemQuantity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1kg"
        android:layout_marginTop="@dimen/dp_4"
        android:textColor="@color/brown"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/feeEachItem"
        app:layout_constraintStart_toStartOf="@id/feeEachItem" />
    <TextView
        android:id="@+id/eggPreference"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Eggless"
        android:textColor="@color/brown"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/itemQuantity"
        app:layout_constraintStart_toStartOf="@id/itemQuantity" />


    <TextView
        android:id="@+id/messageOnCake"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Message: Happy Birthday"
        android:textColor="@color/brown"
        android:textSize="12sp"
        android:maxLines="5"
        android:ellipsize="end"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/eggPreference"
        app:layout_constraintStart_toStartOf="@id/eggPreference" />

    <TextView
        android:id="@+id/totalEachItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹0"
        android:textColor="@color/brown"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/messageOnCake"
        app:layout_constraintStart_toStartOf="@id/messageOnCake" />
</androidx.constraintlayout.widget.ConstraintLayout>
