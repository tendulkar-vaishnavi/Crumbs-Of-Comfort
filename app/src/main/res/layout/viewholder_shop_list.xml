<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="270dp"
    android:layout_margin="13dp"
    app:cardBackgroundColor="@color/cream"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:padding="16dp"
        android:layout_margin="@dimen/dp_24"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Shop Image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageShop"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            style="@style/CornerImageView10dp"
            android:contentDescription="Shop Image" />

        <!-- Shop Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textShopName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crumbz"
                android:textSize="18sp"
                android:textColor="@color/brown_dark"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textShopAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shop Address"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:layout_marginTop="4dp"
                android:maxLines="5"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Call & Message Icons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/imageCall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/call"
                android:layout_marginBottom="8dp"
                android:contentDescription="Call Seller" />

            <ImageView
                android:id="@+id/imageMessage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/message"
                android:contentDescription="Message Seller" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
