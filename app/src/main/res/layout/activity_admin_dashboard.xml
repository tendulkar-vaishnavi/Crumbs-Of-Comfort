<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_margin="@dimen/dp_16">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dp_16">

            <ImageView
                android:id="@+id/imgMenu"
                android:layout_width="25dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="@string/profile"
                android:scaleType="centerCrop"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/textWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome,"
                android:textColor="@color/text_link"
                android:textStyle="bold"
                android:textSize="@dimen/sp_18"
                app:layout_constraintTop_toBottomOf="@id/imgMenu"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/textShopName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_link"
                android:textStyle="bold"
                android:textSize="@dimen/sp_15"
                app:layout_constraintTop_toBottomOf="@id/textWelcome"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="4dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <ScrollView
            android:id="@+id/adminScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:background="#FFF8F1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        android:backgroundTint="#FBE9E7">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/totalUsers"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="102"
                                android:textSize="22sp"
                                android:textColor="#BF360C"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Users"
                                android:textSize="14sp"
                                android:textColor="#5D4037" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Vendors Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        android:backgroundTint="#E8F5E9">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/totalVendors"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15"
                                android:textSize="22sp"
                                android:textColor="#2E7D32"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vendors"
                                android:textSize="14sp"
                                android:textColor="#4E342E" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        android:backgroundTint="#FFFDE7">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/totalOrders"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="287"
                                android:textSize="22sp"
                                android:textColor="#F9A825"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Orders"
                                android:textSize="14sp"
                                android:textColor="#4E342E" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        android:backgroundTint="#F3E5F5">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/totalCustomRequests"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="43"
                                android:textSize="22sp"
                                android:textColor="#8E24AA"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Delivery Partners"
                                android:textSize="14sp"
                                android:textColor="#4E342E" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnApproveVendors"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Approve Vendor Requests"
                        android:backgroundTint="#D7CCC8"
                        android:textColor="#3E2723"
                        android:layout_marginBottom="8dp"
                        android:drawablePadding="8dp" />

                    <Button
                        android:id="@+id/btnApproveDelivery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Approve Delivery Partners"
                        android:backgroundTint="#FFECB3"
                        android:textColor="#3E2723"
                        android:layout_marginBottom="8dp"
                        android:drawablePadding="8dp" />

                    <Button
                        android:id="@+id/btnViewAllOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View All Orders"
                        android:backgroundTint="#C8E6C9"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="8dp" />
                    <Button
                        android:id="@+id/btnManageUsers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Manage Users"
                        android:backgroundTint="#FFCCBC"
                        android:textColor="#4E342E"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View Feedback"
                        android:backgroundTint="#D1C4E9"
                        android:textColor="#4A148C"
                        android:layout_marginBottom="16dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <FrameLayout
            android:id="@+id/adminContentFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFF8F1"/>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        app:headerLayout="@layout/nav_header_admin"
        app:menu="@menu/admin_drawer_menu" />
</androidx.drawerlayout.widget.DrawerLayout>

