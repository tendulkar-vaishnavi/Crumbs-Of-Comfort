<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">
    <ScrollView
        android:id="@+id/vendorDashboardScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/brown_bg_bottom_corner"
                android:padding="30dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/imgMenu"
                        android:layout_width="25dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_menu"
                        android:contentDescription="@string/profile"
                        android:scaleType="centerCrop"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/textWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome,"
                        android:textColor="@color/text_link"
                        android:textStyle="bold"
                        android:textSize="@dimen/sp_18"
                        app:layout_constraintTop_toBottomOf="@id/imgMenu"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:id="@+id/textShopName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_link"
                        android:textStyle="bold"
                        android:textSize="@dimen/sp_15"
                        app:layout_constraintTop_toBottomOf="@id/textWelcome"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="4dp" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_margin="16dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/txtTotalOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Orders Overview"
                    android:textColor="#6D4C41"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:weightSum="3">

                    <TextView
                        android:id="@+id/totalOrders"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Total: 0"
                        android:textColor="#3E2723"
                        android:textSize="14sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/pendingOrders"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Pending: 0"
                        android:textColor="#FF6F00"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/deliveredOrders"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Delivered: 0"
                        android:textColor="#2E7D32"
                        android:textSize="14sp"
                        android:gravity="center" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:weightSum="2"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAddProduct"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Add Product"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/brown_bg"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnManageProduct"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Delete Product"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/brown_bg"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="10dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:text="Recent Orders"
                        android:textSize="18sp"
                        android:textColor="#5D4037"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/txtSeeAllRecentOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_link"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
                <TextView
                    android:id="@+id/textNoOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No orders yet"
                    android:layout_gravity="center"
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/brown_dark"
                    android:textStyle="bold"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="10dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="My Products"
                        android:textSize="18sp"
                        android:textColor="#5D4037"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/txtSeeAllProducts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_link"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
                <TextView
                    android:id="@+id/textNoProducts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No products"
                    android:layout_gravity="center"
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/brown_dark"
                    android:textStyle="bold"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="10dp"
                android:visibility="gone">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/txtCustomRequests"
                        android:text="Custom Requests"
                        android:textSize="18sp"
                        android:textColor="#5D4037"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/txtSeeAllCustomReq"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_link"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
                <TextView
                    android:id="@+id/textNoRequests"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Custom Requests"
                    android:layout_gravity="center"
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/brown_dark"
                    android:textStyle="bold"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewRequests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="@dimen/dp_10">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/txtPreviousOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Previous Orders"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#3E2723"
                        android:layout_alignParentStart="true"/>

                    <TextView
                        android:id="@+id/txtSeeAllPrevOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_link"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
                <TextView
                    android:id="@+id/textNoPrevOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No previous orders  "
                    android:textSize="@dimen/sp_16"
                    android:layout_gravity="center"
                    android:textColor="@color/brown_dark"
                    android:textStyle="bold"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewPrevOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:paddingBottom="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        app:menu="@menu/vendor_menu"
        app:headerLayout="@layout/drawer_header" />
</androidx.drawerlayout.widget.DrawerLayout>
