<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/back"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/callToSellerBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:src="@drawable/call"
            app:layout_constraintTop_toTopOf="@id/txtShopName"
            app:layout_constraintEnd_toStartOf="@id/msgToSellerBtn" />

        <ImageView
            android:id="@+id/msgToSellerBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/message"
            app:layout_constraintTop_toTopOf="@id/txtShopName"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Shop Name -->
        <TextView
            android:id="@+id/txtShopName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Crumbz Bakery"
            android:textSize="20sp"
            android:textColor="@color/brown"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/backBtn"
            app:layout_constraintStart_toStartOf="@id/backBtn"
            app:layout_constraintEnd_toStartOf="@id/callToSellerBtn"
            android:layout_marginTop="8dp" />

        <!-- Shop Address (Multiline Text) -->
        <TextView
            android:id="@+id/txtShopAddress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="123 Donut Street, Sweet City, Cupcake Land"
            android:textColor="@color/brown"
            android:textSize="14sp"
            android:maxLines="3"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/txtShopName"
            app:layout_constraintStart_toStartOf="@id/txtShopName"
            app:layout_constraintEnd_toEndOf="@id/txtShopName"
            android:layout_marginTop="4dp" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/shopView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:padding="@dimen/dp_8"
        app:layout_constraintTop_toBottomOf="@id/txtShopAddress"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:clipToPadding="false" />

    </androidx.constraintlayout.widget.ConstraintLayout>
